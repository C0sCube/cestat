    "field_names": [
        "bench_code",
        "bench_name",
        "order_type",
        "serial",
        "case_no",
        "parties",
        "date",
        "pdf_url"
    ],
    "select_cols": [
        "bench_name",
        "order_type",
        "case_no",
        "parties",
        "date",
        "pdf_url"
    ],
    "notes": [
        "THE API as of now returns the entire data in one go.",
        "Keep the order for field_names the same do not change them",
        "select_cols can have varied names"
    ]
}